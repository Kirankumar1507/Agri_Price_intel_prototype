# Streamlit secrets template.
#
# Local dev:  copy this file to .streamlit/secrets.toml  (gitignored) OR use a .env file.
# Cloud:      paste these keys into Streamlit Community Cloud → app → Settings → Secrets.
#
# The app bridges these into os.environ at startup (see app.py), so the same keys
# work whether they come from Cloud Secrets, a local secrets.toml, or .env.

# Required for live mandi prices from data.gov.in (free key: https://data.gov.in/).
# Without it the app runs in demo mode (cached / empty prices).
DATA_GOV_API_KEY = "your-data-gov-in-key"

# Optional — enables the LLM narratives (verdict headline, market overview, scheme
# explainers). Without it those sections show a localized "unavailable" note.
GEMINI_API_KEY = "your-gemini-api-key"

# Optional — override the default Gemini model.
# GEMINI_MODEL = "gemini-1.5-flash"
