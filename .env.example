# Agmarknet mandi price API — free, register at https://data.gov.in/ for a key
DATA_GOV_API_KEY=

# Ollama host — default localhost:11434; override only if remote
OLLAMA_HOST=http://localhost:11434

# Model name — must already be pulled via `ollama pull qwen2.5:7b-instruct`
OLLAMA_MODEL=qwen2.5:7b-instruct
